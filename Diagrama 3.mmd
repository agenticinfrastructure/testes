    %% FLUXO PRINCIPAL
    USER --> CLOUDFLARE
    CLOUDFLARE --> INPUT_VAL
    INPUT_VAL --> WEB
    INPUT_VAL --> MOBILE
    INPUT_VAL --> API_CLIENT

    WEB --> API
    MOBILE --> API
    API_CLIENT --> API

    API --> RATE_LIMIT
    RATE_LIMIT --> AUTH_MW
    AUTH_MW --> QUOTA
    QUOTA --> TASK_ROUTE

    TASK_ROUTE --> TASK_ROUTER
    TASK_ROUTER --> STATE_MACHINE
    STATE_MACHINE --> PUBSUB

    PUBSUB --> TOPIC_CREATED
    TOPIC_CREATED --> EXECUTOR

    EXECUTOR --> TOPIC_ASSIGNED
    TOPIC_ASSIGNED --> PLANNER

    PLANNER --> SUBTASK_GEN
    SUBTASK_GEN --> DEP_RESOLVER
    DEP_RESOLVER --> PUBSUB

    TASK_ROUTER --> RESEARCHER
    TASK_ROUTER --> CODER
    TASK_ROUTER --> VERIFIER

    CODER --> E2B
    E2B --> SHELL_EXEC
    E2B --> FILE_OPS
    E2B --> CODE_EXEC
    SANDBOX_POLICY -.-> E2B

    RESEARCHER --> WEB_SCRAPER
    RESEARCHER --> FACT_CHECK

    PLANNER --> MEM_STORE
    RESEARCHER --> MEM_STORE
    CODER --> MEM_STORE
    VERIFIER --> MEM_STORE
    MEM_STORE --> CTX_CTRL
    CTX_CTRL --> EXECUTOR

    EXECUTOR --> RESULT_FMT
    RESULT_FMT --> API

    EXECUTOR --> TOPIC_CLARIFY
    TOPIC_CLARIFY --> CLARIFY_HANDLER
    CLARIFY_HANDLER --> USER

    TOPIC_FAILED --> RETRY
    RETRY --> FALLBACK
    FALLBACK --> TASK_ROUTER

    PLANNER -.-> MODEL_SELECTOR
    RESEARCHER -.-> MODEL_SELECTOR
    CODER -.-> MODEL_SELECTOR
    VERIFIER -.-> MODEL_SELECTOR

    MODEL_SELECTOR --> COST_OPT
    MODEL_SELECTOR --> LATENCY_OPT
    MODEL_SELECTOR --> CLAUDE_OPUS
    MODEL_SELECTOR --> CLAUDE_SONNET
    MODEL_SELECTOR --> CLAUDE_HAIKU
    MODEL_SELECTOR --> QWEN_MAX
    MODEL_SELECTOR --> QWEN_TURBO
    MODEL_SELECTOR --> QWQ_32B
    MODEL_SELECTOR --> GEMINI_PRO
    MODEL_SELECTOR --> GEMINI_FLASH

    MODEL_SELECTOR -.-> NANOBANANA
    NANOBANANA --> IMAGEN
    NANOBANANA --> DALLE

    INPUT_FILTER -.-> EXECUTOR
    OUTPUT_FILTER -.-> EXECUTOR
    POLICY_ENGINE -.-> TASK_ROUTER
    ISOLATION -.-> EXECUTOR
    ISOLATION -.-> PLANNER
    ISOLATION -.-> RESEARCHER
    ISOLATION -.-> CODER

    API --> POSTGRES
    MEM_STORE --> REDIS
    CODER --> GCS

    API -.-> PROMETHEUS
    TASK_ROUTER -.-> PROMETHEUS
    EXECUTOR -.-> PROMETHEUS
    PLANNER -.-> PROMETHEUS
    CODER -.-> PROMETHEUS

    API -.-> LOGS
    EXECUTOR -.-> LOGS
    LOGS --> LOG_AGG

    API -.-> TRACING
    TASK_ROUTER -.-> TRACING
    TRACING --> SPANS

    PROMETHEUS --> GRAFANA
    PROMETHEUS --> ALERTS

    GKE --> API_DEPLOY
    GKE --> AGENT_WORKERS
    GKE --> ORCH_DEPLOY

    API_DEPLOY --> API
    AGENT_WORKERS --> EXECUTOR
    AGENT_WORKERS --> PLANNER
    AGENT_WORKERS --> RESEARCHER
    AGENT_WORKERS --> CODER
    AGENT_WORKERS --> VERIFIER
    ORCH_DEPLOY --> TASK_ROUTER

    K8S_SEC --> SECRET_MGR
    SECRET_MGR -.-> API
    SECRET_MGR -.-> AGENT_WORKERS

    GH_ACTIONS --> CLOUD_BUILD
    CLOUD_BUILD --> ARGOCD
    ARGOCD --> GKE

